{
  "servers": {
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp"
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@microsoft/mcp-server-playwright"]
    },
    "rapidapi-network-as-code": {
      "command": "npx",
      "args": [
        "mcp-remote",
        "https://mcp.rapidapi.com",
        "--header",
        "x-api-host: network-as-code.p.rapidapi.com",
        "--header",
        "x-api-key: ${env:RAPIDAPI_KEY}"
      ]
    }
  }
}
